@model GestionEmploiTemps.Web.Models.Niveau

@{
    ViewData["Title"] = "Modifier Niveau";
}

<div class="max-w-xl mx-auto bg-white p-6 rounded-xl shadow-lg">

    <h1 class="text-2xl font-bold text-blue-900 mb-6">
        Modifier Niveau
    </h1>

    <form method="post" asp-action="EditNiveau">

        <!-- 🔥 ID caché -->
        <input type="hidden" name="id" value="@Model.IdNiveau" />

        <div class="mb-4">

            <label class="block mb-2 font-medium">Nom Niveau</label>

            <input type="text"
                   name="nom"
                   value="@Model.Nom"
                   class="w-full border p-3 rounded-lg focus:ring-2 focus:ring-blue-900 outline-none" />

        </div>

        <div class="flex gap-3">

            <button type="submit"
                    class="bg-blue-900 text-white px-5 py-2 rounded-lg hover:bg-blue-700">

                Modifier

            </button>

            <a asp-action="Index"
               class="bg-gray-500 text-white px-5 py-2 rounded-lg hover:bg-gray-700">

                Annuler

            </a>

        </div>

    </form>

</div>