
@model GestionEmploiTemps.Web.Models.ViewModels.AcademiqueVM
@{
    

<div class="max-w-2xl mx-auto bg-white p-6 rounded-xl shadow">

    <h1 class="text-2xl font-bold text-blue-900 mb-6">
        Modifier Parcours
    </h1>

    <form method="post" asp-action="EditParcours">

        <!-- ID -->
        <input type="hidden" name="id" value="@Model.IdParcours" />

        <!-- Nom parcours -->
        <div class="mb-4">
            <label class="block mb-2">Nom Parcours</label>
            <input type="text"
                   name="nom"
                   value="@Model.NouveauParcours"
                   class="w-full border p-3 rounded-lg" />
        </div>

        <!-- Niveau -->
        <div class="mb-4">
            <label class="block mb-2">Niveau</label>

            <select name="idNiveau" class="w-full border p-3 rounded-lg">

                @foreach (var n in Model.Niveaux)
                {
                    <option value="@n.IdNiveau"
                            selected="@(n.IdNiveau == Model.IdNiveau)">
                        @n.Nom
                    </option>
                }

            </select>

        </div>

        <button class="bg-blue-900 text-white px-5 py-2 rounded">
            Modifier
        </button>

    </form>

</div>
}
