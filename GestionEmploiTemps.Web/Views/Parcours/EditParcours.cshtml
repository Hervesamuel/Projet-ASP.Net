@model GestionEmploiTemps.Web.Models.ViewModels.AcademiqueVM

@{
    ViewData["Title"] = "Modifier Parcours";
}

<div class="max-w-xl mx-auto bg-white p-6 rounded-xl shadow-lg">

    <h1 class="text-2xl font-bold text-blue-900 mb-6">
        Modifier Parcours
    </h1>

    <form method="post" asp-action="EditParcours">

        <!-- 🔥 ID caché -->
        <input type="hidden" name="id" value="@Model.IdParcours" />

        <div class="mb-4">

            <label class="block mb-2 font-medium">Nom Parcours</label>

            <input type="text"
                   name="nom"
                   value="@Model.NouveauParcours"
                   class="w-full border p-3 rounded-lg focus:ring-2 focus:ring-blue-900 outline-none" />

        </div>

        <div class="mb-4">

            <label class="block mb-2 font-medium">Niveau</label>

            <select name="idNiveau"
                    class="w-full border p-3 rounded-lg">

                @foreach (var n in Model.Niveaux)
                {
                    <option value="@n.IdNiveau">
                        @n.Nom
                    </option>
                }

            </select>

        </div>

        <div class="flex gap-3">

            <button type="submit"
                    class="bg-blue-900 text-white px-5 py-2 rounded-lg hover:bg-blue-700">

                Modifier

            </button>

            <a asp-action="Index"
               class="bg-gray-500 text-white px-5 py-2 rounded-lg hover:bg-gray-700">

                Annuler

            </a>

        </div>

    </form>

</div>