@model List<GestionEmploiTemps.Web.Models.Creneau>

@{
    ViewData["Title"] = "Gestion Créneaux";
}

<!-- TOAST -->
@if (TempData["Success"] != null)
{
    <div class="bg-green-600 text-white p-3 rounded mb-3">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="bg-red-600 text-white p-3 rounded mb-3">
        @TempData["Error"]
    </div>
}

<!-- FORM -->
<div class="bg-gray-100 p-4 rounded mb-6">

    <form method="post" asp-action="Create" class="flex gap-3">

        <select name="Jour" class="border p-2">
            <option>Lundi</option>
            <option>Mardi</option>
            <option>Mercredi</option>
            <option>Jeudi</option>
            <option>Vendredi</option>
            <option>Samedi</option>
        </select>

        <input type="time" name="HeureDebut" class="border p-2" />
        <input type="time" name="HeureFin" class="border p-2" />

        <button class="bg-blue-900 text-white px-4 py-2 rounded">
            Ajouter
        </button>

    </form>

</div>

<!-- TABLE -->
<table class="w-full border">

    <thead class="bg-blue-900 text-white">
        <tr>
            <th class="p-2">Jour</th>
            <th class="p-2">Début</th>
            <th class="p-2">Fin</th>
            <th class="p-2">Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var c in Model)
        {
            <tr class="text-center border">

                <td class="p-2">@c.Jour</td>
                <td class="p-2">@c.HeureDebut</td>
                <td class="p-2">@c.HeureFin</td>

                <td class="p-2">

                    <a href="/Creneau/Edit?id=@c.IdCreneau"
                       class="bg-blue-600 text-white px-3 py-1 rounded">
                        Modifier
                    </a>

                    <form method="post"
                          asp-action="Delete"
                          class="inline">

                        <input type="hidden" name="id" value="@c.IdCreneau" />

                        <form method="post"
                              asp-action="Delete"
                              asp-controller="Creneau"
                              class="inline">

                            <input type="hidden" name="id" value="@c.IdCreneau" />

                            <button type="submit"
                                    class="bg-red-600 text-white px-3 py-1 rounded ml-2"
                                    onclick="return confirm('Supprimer ce créneau ?')">

                                Supprimer

                            </button>

                        </form>

                    </form>

                </td>

            </tr>
        }
    </tbody>

</table>