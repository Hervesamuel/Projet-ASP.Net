@model GestionEmploiTemps.Web.Models.Creneau

@{
    ViewData["Title"] = "Modifier Créneau";
}

<div class="bg-white p-6 rounded shadow">

    <h2 class="text-2xl font-bold text-blue-900 mb-4">
        Modifier Créneau
    </h2>
    <form method="post" asp-action="Edit">
        <input type="hidden" asp-for="IdCreneau" />

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

            <div>
                <label class="block mb-2">Jour</label>

                <select asp-for="Jour" class="border p-2 w-full">
                    <option>Lundi</option>
                    <option>Mardi</option>
                    <option>Mercredi</option>
                    <option>Jeudi</option>
                    <option>Vendredi</option>
                    <option>Samedi</option>
                </select>
            </div>
            <div>
                <label class="block mb-2">Heure Début</label>
                <input asp-for="HeureDebut" type="time" class="border p-2 w-full" />
            </div>
            <div>
                <label class="block mb-2">Heure Fin</label>
                <input asp-for="HeureFin" type="time" class="border p-2 w-full" />
            </div>

        </div>
        <button class="mt-6 bg-blue-900 text-white px-4 py-2 rounded">
            Modifier
        </button>

    </form>

</div>