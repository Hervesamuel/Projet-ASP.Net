```cshtml
@model GestionEmploiTemps.Web.Models.ViewModels.SeanceVM

@{
    ViewData["Title"] = "Gestion Séances";
}

<!-- 🔔 NOTIFICATIONS -->
@if (TempData["Success"] != null)
{
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
        @TempData["Error"]
    </div>
}

<div class="bg-white rounded-2xl shadow-xl p-8">

    <!-- HEADER -->
    <div class="flex justify-between items-center mb-8">

        <div>
            <h1 class="text-4xl font-bold text-blue-900">
                Gestion des Séances
            </h1>

            <p class="text-gray-500 mt-1">
                Gestion complète des emplois du temps
            </p>
        </div>

    </div>

    <!-- FORM -->
    <div class="bg-gray-50 rounded-xl p-6 mb-10 border">

        <h2 class="text-2xl font-bold text-blue-900 mb-6">
            Ajouter une Séance
        </h2>

        <form method="post" asp-action="Create">

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

                <!-- PARCOURS -->
                <div>
                    <label class="block mb-2 font-semibold text-gray-700">
                        Parcours
                    </label>

                    <select asp-for="NouvelleSeance.IdParcours"
                            class="w-full border rounded-lg p-3 focus:ring-2 focus:ring-blue-900 outline-none">

                        <option value="">Sélectionner</option>

                        @foreach (var p in Model.Parcours)
                        {
                            <option value="@p.IdParcours">
                                @p.Nom
                            </option>
                        }

                    </select>
                </div>

                <!-- MATIERE -->
                <div>
                    <label class="block mb-2 font-semibold text-gray-700">
                        Matière
                    </label>

                    <select asp-for="NouvelleSeance.IdMatiere"
                            class="w-full border rounded-lg p-3 focus:ring-2 focus:ring-blue-900 outline-none">

                        <option value="">Sélectionner</option>

                        @foreach (var m in Model.Matieres)
                        {
                            <option value="@m.IdMatiere">
                                @m.Nom
                            </option>
                        }

                    </select>
                </div>

                <!-- ENSEIGNANT -->
                <div>
                    <label class="block mb-2 font-semibold text-gray-700">
                        Enseignant
                    </label>

                    <select asp-for="NouvelleSeance.IdEns"
                            class="w-full border rounded-lg p-3 focus:ring-2 focus:ring-blue-900 outline-none">

                        <option value="">Sélectionner</option>

                        @foreach (var e in Model.Enseignants)
                        {
                            <option value="@e.IdEns">
                                @e.Nom
                            </option>
                        }

                    </select>
                </div>

                <!-- SALLE -->
                <div>
                    <label class="block mb-2 font-semibold text-gray-700">
                        Salle
                    </label>

                    <select asp-for="NouvelleSeance.IdSalle"
                            class="w-full border rounded-lg p-3 focus:ring-2 focus:ring-blue-900 outline-none">

                        <option value="">Sélectionner</option>

                        @foreach (var s in Model.Salles)
                        {
                            <option value="@s.IdSalle">
                                @s.Nom
                            </option>
                        }

                    </select>
                </div>

                <!-- CRENEAU -->
                <div>
                    <label class="block mb-2 font-semibold text-gray-700">
                        Créneau
                    </label>

                    <select asp-for="NouvelleSeance.IdCreneau"
                            class="w-full border rounded-lg p-3 focus:ring-2 focus:ring-blue-900 outline-none">

                        <option value="">Sélectionner</option>

                        @foreach (var c in Model.Creneaux)
                        {
                            <option value="@c.IdCreneau">
                                @c.Jour |
                                @c.HeureDebut -
                                @c.HeureFin
                            </option>
                        }

                    </select>
                </div>

            </div>

            <!-- BUTTON -->
            <button class="mt-8 bg-blue-900 hover:bg-blue-700 text-white px-6 py-3 rounded-xl font-semibold transition">

                Enregistrer la Séance

            </button>

        </form>

    </div>

    <!-- TABLE -->
    <div class="overflow-x-auto">

        <table class="w-full border-collapse overflow-hidden rounded-xl">

            <thead>

                <tr class="bg-blue-900 text-white">

                    <th class="p-4">Parcours</th>
                    <th class="p-4">Matière</th>
                    <th class="p-4">Enseignant</th>
                    <th class="p-4">Salle</th>
                    <th class="p-4">Créneau</th>
                    <th class="p-4">Actions</th>

                </tr>

            </thead>

            <tbody>

                @if (Model.Seances != null && Model.Seances.Any())
                {
                    @foreach (var s in Model.Seances)
                    {
                        <tr class="text-center border-b hover:bg-gray-50 transition">

                            <td class="p-4">
                                @s.Parcours?.Nom
                            </td>

                            <td class="p-4">
                                @s.Matiere?.Nom
                            </td>

                            <td class="p-4">
                                @s.Enseignant?.Nom
                            </td>

                            <td class="p-4">
                                @s.Salle?.Nom
                            </td>

                            <td class="p-4">
                                @s.Creneau?.Jour
                                |
                                @s.Creneau?.HeureDebut
                                -
                                @s.Creneau?.HeureFin
                            </td>

                            <td class="p-4">

                                <!-- EDIT -->
                                <a asp-action="Edit"
                                   asp-route-id="@s.IdSeance"
                                   class="bg-blue-700 hover:bg-blue-600 text-white px-4 py-2 rounded-lg">

                                    Modifier

                                </a>

                                <!-- DELETE -->
                                <form method="post"
                                      asp-action="Delete"
                                      class="inline">

                                    <input type="hidden"
                                           name="id"
                                           value="@s.IdSeance" />

                                    <button type="submit"
                                            onclick="return confirm('Supprimer cette séance ?')"
                                            class="bg-red-600 hover:bg-red-500 text-white px-4 py-2 rounded-lg ml-2">

                                        Supprimer

                                    </button>

                                </form>

                            </td>

                        </tr>
                    }
                }
                else
                {
                    <tr>

                        <td colspan="6"
                            class="text-center text-gray-500 p-6">

                            Aucune séance enregistrée

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>
```
