@model List<GestionEmploiTemps.Web.Models.Matiere>

@{
    ViewData["Title"] = "Gestion Matières";
}

<div id="toast"
     class="hidden fixed top-5 right-5 px-4 py-3 rounded-lg shadow-lg text-white z-50">
</div>

<!--TEMPDATA : notification après actions -->
@if (TempData["Success"] != null)
{
    <script>
        window.onload = function () {
            showToast("@TempData["Success"]", false);
        };
    </script>
}

@if (TempData["Error"] != null)
{
    <script>
        window.onload = function () {
            showToast("@TempData["Error"]", true);
        };
    </script>
}

<div class="bg-white rounded-xl shadow-lg p-6">

    <!-- 🟦 TITRE -->
    
    <div class="flex justify-between items-center mb-6">

        <div>

            <h1 class="text-3xl font-bold text-blue-900">
                Gestion des Matières
            </h1>

            <p class="text-gray-500">
                Ajouter et gérer les matières
            </p>

        </div>

    </div>

    <!-- 🟩 FORMULAIRE AJOUT -->
   
    <div class="bg-gray-50 p-6 rounded-lg mb-8 border">

        <h2 class="text-xl font-bold text-blue-900 mb-4">
            Ajouter une Matière
        </h2>

        <!-- 🔥 connecté au controller MVC -->
        <form method="post" asp-action="Create">

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

                <div>

                    <label class="block mb-2 font-medium">
                        Nom Matière
                    </label>

                    <!-- 🔥 name important pour binder -->
                    <input type="text"
                           name="Nom"
                           placeholder="Ex : Programmation Web"
                           class="w-full border p-3 rounded-lg focus:ring-2 focus:ring-blue-900 outline-none" />

                </div>

            </div>

            <button type="submit"
                    class="mt-6 bg-blue-900 text-white px-5 py-3 rounded-lg hover:bg-blue-700 transition">

                Enregistrer

            </button>

        </form>

    </div>


    <!-- 📋 TABLEAU -->
    <div class="overflow-x-auto">

        <table class="w-full border-collapse overflow-hidden rounded-lg shadow">

            <thead>

                <tr class="bg-blue-900 text-white">

                    <th class="p-3 border">
                        Nom Matière
                    </th>

                    <th class="p-3 border w-52">
                        Actions
                    </th>

                </tr>

            </thead>

            <tbody>

                <!-- 🔥 données venant du backend -->
                @if (Model != null && Model.Any())
                {
                    @foreach (var matiere in Model)
                    {
                        <tr class="text-center hover:bg-gray-100 transition">

                            <td class="border p-3">
                                @matiere.Nom
                            </td>

                            <td class="border p-3 space-x-2">

                                <!-- 🔵 MODIFIER -->
                             
                                <a asp-action="Edit"
                                   asp-route-id="@matiere.IdMatiere"
                                   class="bg-blue-700 text-white px-3 py-1 rounded hover:bg-blue-800 transition">

                                    Modifier

                                </a>

                                
                                <!-- 🔴 SUPPRIMER -->
            
                                <form method="post"
                                      asp-action="Delete"
                                      asp-route-id="@matiere.IdMatiere"
                                      class="inline">

                                    <button type="submit"
                                            onclick="return confirm('Voulez-vous vraiment supprimer cette matière ?');"
                                            class="bg-red-600 text-white px-3 py-1 rounded hover:bg-red-700 transition">

                                        Supprimer

                                    </button>

                                </form>

                            </td>

                        </tr>
                    }
                }
                else
                {
                    <!-- 🔥 si aucune donnée -->
                    <tr>

                        <td colspan="2"
                            class="text-center p-6 text-gray-500">

                            Aucune matière trouvée

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>



<!-- 🟨 JAVASCRIPT TOAST -->

<script>

    // 🔥 notification dynamique
    function showToast(message, isError = false) {

        const toast = document.getElementById("toast");

        toast.innerText = message;

        toast.className =
            "fixed top-5 right-5 px-4 py-3 rounded-lg shadow-lg text-white z-50 " +
            (isError
                ? "bg-red-600"
                : "bg-green-600");

        toast.classList.remove("hidden");

        // disparition après 3 secondes
        setTimeout(() => {

            toast.classList.add("hidden");

        }, 3000);
    }

</script>