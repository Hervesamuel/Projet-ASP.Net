@model List<GestionEmploiTemps.Web.Models.Enseignant>
@if (TempData["Success"] != null)
{
    <script>
        showToast("@TempData["Success"]", false);
    </script>
}

@if (TempData["Error"] != null)
{
    <script>
        showToast("@TempData["Error"]", true);
    </script>
}

@{
    ViewData["Title"] = "Gestion Enseignants";
}
<div id="toast"
      class="hidden fixed top-5 right-5 px-4 py-3 rounded-lg shadow-lg text-white transition">
</div>
<div class="bg-white rounded-xl shadow-lg p-6">

    <!-- Titre -->
    <div class="flex justify-between items-center mb-6">

        <div>
            <h1 class="text-3xl font-bold text-blue-900">
                Gestion des Enseignants
            </h1>

            <p class="text-gray-500">
                Ajouter et gérer les enseignants
            </p>
        </div>

        <button class="bg-blue-900 text-white px-4 py-2 rounded-lg hover:bg-blue-700">
            + Nouvel Enseignant
        </button>

    </div>

    <!-- Formulaire -->
    <div class="bg-gray-50 p-6 rounded-lg mb-8">

        <h2 class="text-xl font-bold text-blue-900 mb-4">
            Ajouter un Enseignant
        </h2>

        <form method="post" asp-action="Create">

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

                <!-- Nom -->
                <div>
                    <label class="block mb-2 font-medium">
                        Nom
                    </label>

                    <input type="text"
                           name="Nom"
                           placeholder="Entrer le nom"
                           class="w-full border p-3 rounded-lg focus:ring-2 focus:ring-blue-900 outline-none" />
                </div>

            </div>

            <button class="mt-6 bg-blue-900 text-white px-5 py-3 rounded-lg hover:bg-blue-700">
                Enregistrer
            </button>

        </form>

    </div>

    <!-- Tableau enseignants -->
    <div class="overflow-x-auto">

        <table class="w-full">

            <thead>
                <tr class="bg-blue-900 text-white">
                    <th class="p-3 border">Nom</th>
                    <th class="p-3 border">Actions</th>
                </tr>
            </thead>

            <tbody>

                @if (Model != null && Model.Any())
                {
                    @foreach (var enseignant in Model)
                    {
                        <tr class="text-center hover:bg-gray-100">

                            <td class="border p-3">
                                @enseignant.Nom
                            </td>

                            <td class="border p-3">

                                <a class="bg-blue-700 text-white px-3 py-1 rounded"
                                   asp-action="Edit"
                                   asp-route-id="@enseignant.IdEns">
                                    Modifier
                                </a>

                                <a class="bg-red-600 text-white px-3 py-1 rounded ml-2"
                                    asp-action="Delete"
                                    asp-route-id="@enseignant.IdEns"
                                    onclick="return confirm('Voulez-vous vraiment supprimer cet enseignant ?');">
                                    Supprimer
                                </a>

                            </td>

                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="2" class="text-center p-4 text-gray-500">
                            Aucun enseignant trouvé
                        </td>
                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

<script>
    function showToast(message, isError = false) {

        const toast = document.getElementById("toast");

        toast.innerText = message;

        toast.className =
            "fixed top-5 right-5 px-4 py-3 rounded-lg shadow-lg text-white transition " +
            (isError ? "bg-red-600" : "bg-green-600");

        toast.classList.remove("hidden");

        setTimeout(() => {
            toast.classList.add("hidden");
        }, 3000);
    }
</script>